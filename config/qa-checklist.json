{
    "version": "1.0.0",
    "name": "Elite Graphic Design QA Checklist",
    "description": "Rules engine for the visual-qa-auditor.py script to enforce the 8px grid and WCAG contrast.",
    "grid_enforcement": {
        "base_unit": 8,
        "allowed_multiples": [
            0.5,
            1,
            1.5,
            2,
            3,
            4,
            5,
            6,
            8,
            10,
            12,
            16
        ],
        "strictly_enforced_properties": [
            "margin",
            "margin-top",
            "margin-right",
            "margin-bottom",
            "margin-left",
            "padding",
            "padding-top",
            "padding-right",
            "padding-bottom",
            "padding-left",
            "gap",
            "column-gap",
            "row-gap",
            "border-radius",
            "height",
            "width",
            "min-height",
            "min-width",
            "max-height",
            "max-width"
        ],
        "allow_percentages": true,
        "allow_viewport_units": true
    },
    "contrast_requirements": {
        "standard_text_minimum": 4.5,
        "large_text_minimum": 3.0,
        "ui_components_minimum": 3.0,
        "financial_data_minimum": 7.0,
        "large_text_threshold_px": 24,
        "large_text_bold_threshold_px": 18
    },
    "typography_rules": {
        "body_line_height_min": 1.4,
        "body_line_height_max": 1.6,
        "heading_line_height_min": 1.1,
        "heading_line_height_max": 1.3,
        "max_font_families_per_file": 3
    },
    "color_smells": {
        "pure_black": [
            "#000000",
            "rgb(0,0,0)",
            "rgba(0,0,0,1)",
            "black"
        ],
        "pure_black_reason": "Pure black causes eye strain. Use a dark gray like #0F172A.",
        "pure_white": [
            "#FFFFFF",
            "rgb(255,255,255)",
            "rgba(255,255,255,1)",
            "white"
        ],
        "pure_white_reason": "Pure white can glare. Off-white (#F8FAFC) is preferred."
    }
}